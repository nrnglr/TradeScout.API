# TradeScout API - Environment Variables
# Copy this file to .env and fill in your actual values
# .env file is gitignored and should never be committed

# Gemini AI API Key
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_api_key_here

# Database Connection String
# Format: Host=localhost;Port=5432;Database=dbname;Username=user;Password=pass
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=TradeScoutDb;Username=postgres;Password=your_password

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_min_32_chars_long
JWT_ISSUER=TradeScout.API
JWT_AUDIENCE=TradeScout.Client
JWT_EXPIRATION_MINUTES=1440

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Optional: Logging Level
LOG_LEVEL=Information
