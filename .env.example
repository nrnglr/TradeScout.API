# ===========================================
# TradeScout API - Environment Variables
# ===========================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env
# .env dosyası gitignore'da ve asla commit edilmemeli!
# ===========================================

# ===== DATABASE =====
DATABASE_URL=Host=YOUR_DB_HOST;Port=5432;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD

# ===== JWT AUTHENTICATION =====
JWT_SECRET_KEY=YOUR_SUPER_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG

# ===== GEMINI AI API =====
# Tek API key kullanımı
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Çoklu API key kullanımı (yüksek trafik için)
GEMINI_API_KEY_1=YOUR_GEMINI_API_KEY_1
GEMINI_API_KEY_2=YOUR_GEMINI_API_KEY_2
GEMINI_API_KEY_3=YOUR_GEMINI_API_KEY_3
GEMINI_API_KEY_4=YOUR_GEMINI_API_KEY_4
GEMINI_API_KEY_5=YOUR_GEMINI_API_KEY_5

# ===== EMAIL (RESEND) =====
RESEND_API_KEY=YOUR_RESEND_API_KEY

# ===== APPLICATION =====
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5100
